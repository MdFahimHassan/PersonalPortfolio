# EmailJS credentials used by the Contact form (src/components/Contact.tsx)
# Get these from https://dashboard.emailjs.com after creating a service + template.
# These are the EmailJS *public* client keys — safe to expose in the browser bundle,
# but keep your own values out of git (this file is just a template).
VITE_EMAILJS_SERVICE_ID=
VITE_EMAILJS_TEMPLATE_ID=
VITE_EMAILJS_PUBLIC_KEY=
